# ========================================
# MERN Review System - Environment Configuration
# ========================================

# MongoDB Connection String
# Replace with your MongoDB Atlas connection string or local MongoDB URL
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<database>?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://aryankaushik541_db_user:wiA6zyP8cWjaq5Bu@cluster0.cikdgjg.mongodb.net/feedbackDB?retryWrites=true&w=majority

# Server Configuration
# Port on which the backend server will run
PORT=5000

# JWT Secret Key
# IMPORTANT: Change this to a strong, random secret key in production
# Generate a secure key using: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=4f8e9a6c2d1b7e3a9c5f8a2d6e1b9c4f7a8e2d5c6b1a9f3e8d4c7b5

# JWT Token Expiration
# How long the JWT token remains valid (e.g., 1h, 7d, 30d)
JWT_EXPIRES_IN=7d

# Frontend URL Configuration
# IMPORTANT: Set this to your actual frontend URL in production
# This is used for CORS and email reset links
FRONTEND_URL=https://booking-review-system.vercel.app

# Node Environment
# Options: development, production, test
NODE_ENV=production

# ========================================
# Email Configuration (Gmail SMTP)
# ========================================
# CRITICAL: Use Gmail App Password, NOT your regular Gmail password
# 
# How to get Gmail App Password:
# 1. Go to Google Account Settings (https://myaccount.google.com/)
# 2. Security → Enable 2-Step Verification (if not enabled)
# 3. Security → App passwords
# 4. Select app: Mail, Select device: Other (Custom name: "Review System")
# 5. Click Generate
# 6. Copy the 16-character password (REMOVE ALL SPACES!)
# 7. Paste it in EMAIL_APP_PASSWORD below
#
# IMPORTANT NOTES:
# - Remove ALL spaces from the app password
# - Example: "abcd efgh ijkl mnop" should be "abcdefghijklmnop"
# - Do NOT use your regular Gmail password
# - 2-Step Verification MUST be enabled

EMAIL_USER=aryankaushik541@gmail.com
EMAIL_APP_PASSWORD=yjjhugimwdpmakrh

# ========================================
# Booking.com Guest Review API Configuration
# ========================================
# Official API: https://supply-xml.booking.com/review-api/properties/{hotel_id}/reviews
# Authentication: Basic Auth using machine account credentials

# Your hotel/property ID from Booking.com
# Example: 123456
# Find it in: Booking.com Extranet → Property Settings → Property ID
BOOKING_HOTEL_ID=

# Booking.com API Credentials (Machine Account)
# IMPORTANT: Create a machine account in Booking.com Extranet
# How to get API credentials:
# 1. Login to Booking.com Extranet (https://admin.booking.com)
# 2. Go to Settings → API Access
# 3. Create a new machine account
# 4. Copy the username and password
# 5. Paste them below

# Machine account username (usually looks like: property_123456_api)
BOOKING_API_USERNAME=

# Machine account password (generated by Booking.com)
BOOKING_API_PASSWORD=

# ========================================
# NOTES FOR BOOKING.COM API:
# ========================================
# 1. You MUST have a machine account to access the Guest Review API
# 2. Contact Booking.com support if you don't have API access
# 3. API returns up to 100 reviews per request (use pagination for more)
# 4. Reviews are sorted from newest to oldest by default
# 5. Property responses go through moderation (up to 48 hours)
# 6. Keep your API credentials secure and never commit them to version control

# ========================================
# Optional: File Upload Configuration
# ========================================
# MAX_FILE_SIZE=5242880
# UPLOAD_PATH=./uploads

# ========================================
# Database Configuration
# ========================================
# DB_NAME=feedbackDB
# DB_MAX_POOL_SIZE=10
# DB_MIN_POOL_SIZE=2

# ========================================
# Security Configuration
# ========================================
# BCRYPT_ROUNDS=10
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX_REQUESTS=100

# ========================================
# FINAL CHECKLIST FOR VERCEL DEPLOYMENT:
# ========================================
# 1. ✅ Copy these variables to Vercel Environment Variables
# 2. ✅ MONGODB_URI - Your MongoDB Atlas connection string
# 3. ✅ JWT_SECRET - Generate a secure random key
# 4. ✅ FRONTEND_URL - Set to your frontend Vercel URL
# 5. ✅ EMAIL_USER - Your Gmail address
# 6. ✅ EMAIL_APP_PASSWORD - Gmail App Password (NO SPACES!)
# 7. ✅ NODE_ENV - Set to "production"
# 8. ✅ Never commit .env file to version control
# 9. ✅ Redeploy after adding environment variables
# 10. ✅ Test /api/config/email endpoint to verify email setup
