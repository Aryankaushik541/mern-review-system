# MongoDB Connection String
# For local MongoDB:
MONGODB_URI=mongodb://localhost:27017/review-system

# For MongoDB Atlas (cloud):
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/review-system

# Server Port
PORT=5000

# JWT Secret Key (IMPORTANT: Change this in production!)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-use-random-string
